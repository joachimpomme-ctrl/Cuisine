{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/cuisine-ai-knowledge/schemas/rule.schema.json",
  "title": "Cuisine Rule",
  "description": "Règle culinaire atomique exploitable par agents IA et par humains.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "domaine",
    "categorie",
    "sous_categorie",
    "type_regle",
    "titre",
    "regle",
    "conditions",
    "application",
    "erreurs_frequentes",
    "exceptions",
    "niveau",
    "fiabilite",
    "usage_agent"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9]+(?:_[A-Z0-9]+)*_[0-9]{3}$",
      "description": "Identifiant stable, en majuscules, suffixé par un numéro à trois chiffres."
    },
    "domaine": {
      "type": "string",
      "enum": [
        "cuisson",
        "ingredient",
        "assaisonnement",
        "sauce",
        "patisserie",
        "hygiene",
        "conservation",
        "substitution",
        "rattrapage",
        "organisation",
        "materiel",
        "nutrition_pratique",
        "enfants_famille",
        "batch_cooking",
        "anti_gaspillage"
      ]
    },
    "categorie": {
      "type": "string",
      "minLength": 1
    },
    "sous_categorie": {
      "type": "string",
      "minLength": 1
    },
    "type_regle": {
      "type": "string",
      "enum": [
        "principe",
        "procedure",
        "temperature",
        "temps",
        "erreur_a_eviter",
        "rattrapage",
        "substitution",
        "hygiene",
        "conservation",
        "adaptation",
        "diagnostic"
      ]
    },
    "titre": {
      "type": "string",
      "minLength": 5
    },
    "regle": {
      "type": "string",
      "minLength": 20
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "application": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "erreurs_frequentes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "niveau": {
      "type": "string",
      "enum": [
        "fondamental",
        "intermediaire",
        "avance",
        "expert"
      ]
    },
    "fiabilite": {
      "type": "string",
      "enum": [
        "haute",
        "moyenne",
        "contextuelle"
      ]
    },
    "usage_agent": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "conseil_cuisson",
          "adaptation_recette",
          "generation_menu",
          "diagnostic_erreur",
          "substitution_ingredient",
          "securite_alimentaire",
          "optimisation_temps",
          "repas_enfants",
          "batch_cooking",
          "liste_courses",
          "gestion_restes",
          "anti_gaspillage"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
